{
  "info": {
    "_postman_id": "nextpresskit-public-api",
    "name": "NextPressKit Public API",
    "description": "Public and auth endpoints for the NextPressKit backend. Uses {{base_url}}.\n\nAuth: set environment `jwt_auth_source` to `cookie` (default, matches server `JWT_AUTH_SOURCE`) or `header`. Cookie mode uses Postman's cookie jar after `POST /auth/login` (no tokens in JSON). Header mode stores tokens from JSON and sends `Authorization: Bearer …` via the collection pre-request script.\n\n`POST /auth/login` defaults use `{{superadmin_email}}` and `{{superadmin_password}}` (seed defaults: see `SEED_SUPERADMIN_*` in `.env.example`).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const mode = String(pm.environment.get(\"jwt_auth_source\") || \"cookie\").toLowerCase();",
          "pm.request.headers.remove(\"Authorization\");",
          "if (mode === \"header\") {",
          "    const t = pm.environment.get(\"access_token\");",
          "    if (t) {",
          "        pm.request.headers.upsert({ key: \"Authorization\", value: \"Bearer \" + t });",
          "    }",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const mode = String(pm.environment.get(\"jwt_auth_source\") || \"cookie\").toLowerCase();",
              "const name = pm.info.requestName || \"\";",
              "if (mode !== \"cookie\") { return; }",
              "if (name.indexOf(\"POST /auth/refresh\") !== 0 && name.indexOf(\"POST /auth/logout\") !== 0) { return; }",
              "pm.request.body.mode = \"raw\";",
              "pm.request.body.raw = \"\";",
              "pm.request.headers.remove(\"Content-Type\");"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{superadmin_email}}\",\n  \"password\": \"{{superadmin_password}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "    var data = pm.response.json();",
                  "    if (data.tokens && data.tokens.accessToken) {",
                  "        pm.environment.set(\"access_token\", data.tokens.accessToken);",
                  "        pm.environment.set(\"admin_access_token\", data.tokens.accessToken);",
                  "    }",
                  "    if (data.tokens && data.tokens.refreshToken) pm.environment.set(\"refresh_token\", data.tokens.refreshToken);",
                  "    if (data.access_token) { pm.environment.set(\"access_token\", data.access_token); pm.environment.set(\"admin_access_token\", data.access_token); }",
                  "    if (data.refresh_token) pm.environment.set(\"refresh_token\", data.refresh_token);",
                  "    if (data.accessToken) { pm.environment.set(\"access_token\", data.accessToken); pm.environment.set(\"admin_access_token\", data.accessToken); }",
                  "    if (data.refreshToken) pm.environment.set(\"refresh_token\", data.refreshToken);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "POST /auth/refresh",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "    pm.environment.unset(\"access_token\");",
                  "    pm.environment.unset(\"refresh_token\");",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Pages",
      "item": [
        {
          "name": "GET /pages/{slug}",
          "request": {
            "method": "GET",
            "header": [],
