type Post {
  id: ID!
  title: String!
  slug: String!
  excerpt: String
  status: String!
  publishedAt: String
}

type Page {
  id: ID!
  title: String!
  slug: String!
  status: String!
  publishedAt: String
}

type PostConnection {
  posts: [Post!]!
}

type Query {
  post(slug: String!): Post
  posts(limit: Int, offset: Int): PostConnection!
  page(slug: String!): Page
}
