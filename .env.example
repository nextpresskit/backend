# Application
APP_NAME=NextPress
APP_ENV=development
APP_PORT=9090

# Database
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nextpress
DB_USER=postgres
DB_PASSWORD=secret
DB_SSLMODE=disable

# JWT
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# RBAC
# Enables one-time bootstrap endpoint: POST /v1/admin/bootstrap/claim-admin
RBAC_BOOTSTRAP_ENABLED=false

# Media
MEDIA_STORAGE_DIR=storage/uploads
MEDIA_PUBLIC_BASE_URL=/uploads
MEDIA_MAX_UPLOAD_BYTES=10485760