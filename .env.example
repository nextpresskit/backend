# Application
# Human-readable product name (API title, metrics, generated Nginx/README deploy comments).
APP_NAME=NextPressKit
APP_ENV=local
APP_PORT=9090

# Default public hostname for Nginx server_name, mkcert (setup-local-https), and deploy prompts.
# When set, overrides tier placeholders (local: nextpresskit.local; staging/dev/production: api*.example.com).
# Example for local dev: myapi.local (add 127.0.0.1 myapi.local to /etc/hosts).
NEXTPRESS_PUBLIC_HOST=

# Operational names (defaults match upstream NextPressKit; override for your project).
# Structured log field "service" on startup/shutdown.
APP_LOG_IDENTIFIER=nextpresskit-backend
# systemd unit basename (unit is APP_SERVICE_UNIT@<tier>), Nginx site filename on server, deploy artifacts.
APP_SERVICE_UNIT=nextpresskit-backend
# Dev background API: .tmp/<APP_DEV_RUNTIME_BASENAME>-api.pid and -api.log (Unix scripts + Makefile).
APP_DEV_RUNTIME_BASENAME=nextpresskit
# Local mkcert PEM directory: $XDG_DATA_HOME or ~/.local/share/<APP_LOCAL_SSL_SUBDIR>
APP_LOCAL_SSL_SUBDIR=nextpresskit-ssl

# Optional API prefix (examples: "", "/v1"). Leave empty for unversioned paths.
API_BASE_PATH=

# CORS: comma-separated frontend origin(s), no trailing slashes.
# Required when the browser sends credentials (cookies / credentials: include).
# If unset, any origin is allowed with wildcard headers (not compatible with credentials).
CORS_ORIGINS=

# Database
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nextpresskit
DB_USER=postgres
DB_PASSWORD=secret
DB_SSLMODE=disable

# JWT
JWT_SECRET=dev-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Auth transport: where the backend reads access JWTs from.
# Supported values: cookie, header. (Default: cookie)
JWT_AUTH_SOURCE=cookie

# Cookie names used when JWT_AUTH_SOURCE=cookie
JWT_ACCESS_COOKIE_NAME=access_token
JWT_REFRESH_COOKIE_NAME=refresh_token

# Cross-site cookie security attributes (recommended for production)
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAME_SITE=none
JWT_COOKIE_PATH=/
JWT_COOKIE_DOMAIN=

# RBAC
# Enables one-time bootstrap endpoint: POST /admin/bootstrap/claim-admin
RBAC_BOOTSTRAP_ENABLED=false

# Seed defaults (used by `make seed`)
SEED_SUPERADMIN_EMAIL=superadmin@nextpresskit.local
SEED_SUPERADMIN_PASSWORD=SuperAdmin123!

# Media
MEDIA_STORAGE_DIR=storage/uploads
MEDIA_PUBLIC_BASE_URL=/uploads
MEDIA_MAX_UPLOAD_BYTES=10485760

# Rate limiting (Phase 4 hardening)
# Applies in-memory fixed-window rate limits per instance.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PUBLIC_MAX_PER_MINUTE=120
RATE_LIMIT_AUTH_MAX_PER_MINUTE=30
RATE_LIMIT_ADMIN_MAX_PER_MINUTE=60
RATE_LIMIT_REDIS_ENABLED=false
RATE_LIMIT_REDIS_ADDR=
RATE_LIMIT_REDIS_PASSWORD=
RATE_LIMIT_REDIS_DB=0
RATE_LIMIT_REDIS_PREFIX=nextpresskit:ratelimit

# GraphQL (optional; gqlgen). REST remains the primary API.
GRAPHQL_ENABLED=false
GRAPHQL_PATH=/graphql
# Dev-only UI. Only registers when APP_ENV is local or dev (ignored elsewhere).
GRAPHQL_PLAYGROUND_ENABLED=false

# Elasticsearch (optional; full-text search + indexing). PostgreSQL stays source of truth.
ELASTICSEARCH_ENABLED=false
# Comma-separated node URLs, e.g. http://localhost:9200
ELASTICSEARCH_URLS=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_INDEX_PREFIX=nextpresskit
# TLS dev only - never enable in production.
ELASTICSEARCH_INSECURE_SKIP_VERIFY=false
# Create posts index on startup if missing (defaults true when APP_ENV is local or dev).
ELASTICSEARCH_AUTO_CREATE_INDEX=

# Optional: skip the ACME email prompt when using ./scripts/deploy apply-nginx --letsencrypt (non-TTY / CI).
# CERTBOT_EMAIL=you@example.com