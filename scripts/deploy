#!/usr/bin/env bash
# Interactive deploy wizard for NextPressKit: Nginx (+ optional TLS), systemd snippets,
# and optional release (git pull, build, migrate, seed, service restart).
#
# Always interactive. From repo root:
#   ./scripts/deploy
#
# Output: deploy/generated/<slug>/  (gitignored)

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

cyan()  { printf '\033[36m%s\033[0m\n' "$*" >&2; }
green() { printf '\033[32m%s\033[0m\n' "$*" >&2; }
yellow(){ printf '\033[33m%s\033[0m\n' "$*" >&2; }
red()   { printf '\033[31m%s\033[0m\n' "$*" >&2; }

detect_os() {
  case "$(uname -s 2>/dev/null)" in
    Linux*)   echo "linux" ;;
    Darwin*)  echo "darwin" ;;
    MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
    *)        echo "unknown" ;;
  esac
}

tier_to_branch() {
  case "$1" in
    production) echo "main" ;;
    staging)    echo "staging" ;;
    dev)        echo "dev" ;;
    *)          echo "" ;;
  esac
}

prompt() {
  local _default="$1"
  local _text="$2"
  local _line
  read -r -p "${_text} [${_default}]: " _line || true
  if [[ -z "${_line// }" ]]; then
    echo "$_default"
  else
    echo "$_line"
  fi
}

prompt_yn() {
  local _default="$1"
  local _text="$2"
  local _line
  while true; do
    read -r -p "${_text} (y/n) [${_default}]: " _line || true
    _line="${_line:-$_default}"
    case "${_line:0:1}" in
      y|Y) echo y; return 0 ;;
      n|N) echo n; return 0 ;;
    esac
    yellow "Please answer y or n."
  done
}

slugify() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | sed -e 's/[^a-z0-9._-]\+/-/g' -e 's/^-\|-$//g' | cut -c1-48
}

# HTTP-only Nginx server block
write_nginx_http() {
  local out="$1"
  local server_name="$2"
  local listen_port="$3"
  local app_port="$4"
  local deploy_dir="$5"
  local tier="$6"

  cat >"$out" <<EOF
# Generated by scripts/deploy — NextPressKit Nginx (${tier}, HTTP)
# After edits: sudo nginx -t && sudo systemctl reload nginx   (Linux)
#              "\$(brew --prefix nginx)/bin/nginx" -t && brew services restart nginx   (macOS)

server {
    listen ${listen_port};
    server_name ${server_name};

    location /uploads/ {
        alias ${deploy_dir}/storage/uploads/;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
    }

    location / {
        proxy_pass         http://127.0.0.1:${app_port};
        proxy_set_header   Host \$host;
        proxy_set_header   X-Real-IP \$remote_addr;
        proxy_set_header   X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
    }
}
EOF
}

# HTTPS Nginx: optional HTTP→HTTPS redirect + TLS server
write_nginx_https() {
  local out="$1"
  local server_name="$2"
  local listen_http="$3"
  local listen_ssl="$4"
  local app_port="$5"
  local deploy_dir="$6"
  local tier="$7"
  local cert="$8"
  local key="$9"
  local redirect_http="${10:-y}"

  {
    if [[ "$redirect_http" == "y" ]]; then
      cat <<EOF
# Generated by scripts/deploy — NextPressKit Nginx (${tier}, HTTPS)
server {
    listen ${listen_http};
    server_name ${server_name};
    return 301 https://\$host\$request_uri;
}

EOF
    fi
    cat <<EOF
server {
    listen ${listen_ssl} ssl http2;
    server_name ${server_name};

    ssl_certificate     ${cert};
    ssl_certificate_key ${key};

    location /uploads/ {
        alias ${deploy_dir}/storage/uploads/;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
    }

    location / {
        proxy_pass         http://127.0.0.1:${app_port};
        proxy_set_header   Host \$host;
        proxy_set_header   X-Real-IP \$remote_addr;
        proxy_set_header   X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
    }
}
EOF
  } >"$out"
}

write_systemd() {
  local out="$1"
  local tier="$2"
  local deploy_dir="$3"
  local run_user="$4"
  local run_group="$5"

  cat >"$out" <<EOF
# Generated by scripts/deploy — NextPressKit systemd (${tier})
#   sudo cp nextpress-backend@${tier}.service /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now nextpress-backend@${tier}

[Unit]
Description=nextpress-backend (${tier})
After=network.target

[Service]
Type=simple
WorkingDirectory=${deploy_dir}
Environment=APP_ENV=${tier}
EnvironmentFile=${deploy_dir}/.env
ExecStart=${deploy_dir}/bin/server
Restart=always
RestartSec=5
User=${run_user}
Group=${run_group}

[Install]
WantedBy=multi-user.target
EOF
}

write_readme() {
  local out="$1"
  local os_kind="$2"
  local tier="$3"
  local deploy_dir="$4"
  local gen_dir="$5"
  local ssl_mode="$6"
  local server_name="$7"
  local certbot_email="$8"

  cat >"$out" <<EOF
# Generated NextPressKit deploy snippets

- **Tier:** ${tier}
- **App root:** ${deploy_dir}
- **TLS mode:** ${ssl_mode}
- **Files:**
  - \`nginx-nextpress-${tier}.conf\`
  - \`nextpress-backend@${tier}.service\` (if generated)

## TLS notes

EOF

  case "$ssl_mode" in
    letsencrypt)
      cat >>"$out" <<EOF
**Let's Encrypt:** HTTP vhost is in the generated config (port 80). After installing the site:

\`\`\`bash
sudo apt install -y certbot python3-certbot-nginx
sudo certbot --nginx -d ${server_name} --email ${certbot_email} --agree-tos --non-interactive
\`\`\`

Omit \`--non-interactive\` for the first run if you prefer prompts. Then \`sudo nginx -t && sudo systemctl reload nginx\`.

EOF
      ;;
    pem)
      cat >>"$out" <<EOF
**HTTPS (PEM):** Paths are in \`nginx-nextpress-${tier}.conf\`. Renew or replace certificates before expiry, then \`nginx -t\` and reload.

EOF
      ;;
    *)
      cat >>"$out" <<EOF
**HTTP only:** Add TLS later with Certbot (\`docs/DEPLOYMENT.md\`) or mkcert locally (\`docs/deployment/local.md\`).

EOF
      ;;
  esac

  cat >>"$out" <<EOF
## App setup

1. \`.env\` in \`${deploy_dir}\` with \`APP_PORT\`, \`DB_*\`, \`JWT_SECRET\`, and \`APP_ENV\` (systemd sets \`APP_ENV=${tier}\` when enabled).
2. \`make build\` in \`${deploy_dir}\`.

EOF

  if [[ "$os_kind" == "linux" ]]; then
    cat >>"$out" <<EOF
### Ubuntu / Debian

\`\`\`bash
sudo cp ${gen_dir}/nginx-nextpress-${tier}.conf /etc/nginx/sites-available/nextpress-backend-${tier}.conf
sudo ln -sf /etc/nginx/sites-available/nextpress-backend-${tier}.conf /etc/nginx/sites-enabled/
sudo nginx -t && sudo systemctl reload nginx
# If you generated a unit:
sudo cp ${gen_dir}/nextpress-backend@${tier}.service /etc/systemd/system/
sudo systemctl daemon-reload
sudo systemctl enable --now nextpress-backend@${tier}
\`\`\`

EOF
  elif [[ "$os_kind" == "darwin" ]]; then
    local brew_nginx
    brew_nginx="$(brew --prefix nginx 2>/dev/null || echo "/opt/homebrew/opt/nginx")"
    cat >>"$out" <<EOF
### macOS (Homebrew Nginx)

Include \`nginx-nextpress-${tier}.conf\` from \`$(brew --prefix 2>/dev/null || echo /opt/homebrew)/etc/nginx/nginx.conf\` (or \`servers/*\`).

\`\`\`bash
"${brew_nginx}/bin/nginx" -t && brew services restart nginx
\`\`\`

EOF
  else
    cat >>"$out" <<EOF
### Windows / Git Bash

Use \`scripts/deploy.ps1\` in PowerShell, or merge the \`server\` blocks into your Nginx config.

EOF
  fi
}

run_release_pipeline() {
  local tier="$1"
  local branch
  branch="$(tier_to_branch "$tier")"

  if ! command -v go >/dev/null 2>&1; then
    red "Go is not installed. Skipping release build."
    return 1
  fi

  if [[ ! -f .env ]]; then
    red ".env not found in ${ROOT_DIR}. Create it before release."
    return 1
  fi

  if [[ -n "$branch" ]] && [[ -d .git ]]; then
    if [[ "$(prompt_yn y "Git: fetch/checkout/pull branch '${branch}'?")" == "y" ]]; then
      green "=== Git: ${branch} ===" >&2
      git fetch origin
      git checkout "$branch"
      git pull origin "$branch"
    fi
  elif [[ -n "$branch" ]]; then
    yellow "Not a git repository; skipping git pull." >&2
  else
    yellow "Tier '${tier}': skipping git (no mapped branch for local)." >&2
  fi

  green "=== Building binaries ===" >&2
  go env -w CGO_ENABLED=0 >/dev/null 2>&1 || true
  go mod download
  mkdir -p bin
  go build -v -o bin/server ./cmd/api
  go build -v -o bin/migrate ./cmd/migrate
  go build -v -o bin/seed ./cmd/seed

  green "=== Migrations ===" >&2
  set -a
  # shellcheck source=/dev/null
  source .env
  set +a
  ./bin/migrate -command=up

  if [[ "${RUN_SEED_ON_DEPLOY:-}" == "true" ]]; then
    green "=== Seed (RUN_SEED_ON_DEPLOY=true) ===" >&2
    ./bin/seed
  elif [[ "$(prompt_yn n "Run database seeders now?")" == "y" ]]; then
    green "=== Seed ===" >&2
    ./bin/seed
  else
    yellow "Seed skipped." >&2
  fi

  local svc="nextpress-backend@${tier}"
  if [[ "$tier" != "local" ]] && command -v systemctl >/dev/null 2>&1; then
    if systemctl list-units --type=service 2>/dev/null | grep -qF "$svc"; then
      if [[ "$(prompt_yn y "Restart systemd service ${svc}?")" == "y" ]]; then
        green "=== systemctl restart ${svc} ===" >&2
        sudo systemctl restart "$svc"
        sudo systemctl status "$svc" --no-pager || true
      fi
    else
      yellow "systemd unit '${svc}' not active. Start manually: sudo systemctl enable --now ${svc}" >&2
    fi
  elif [[ "$tier" == "local" ]]; then
    yellow "Local tier: restart the API yourself (make run / make start)." >&2
  fi

  green "=== Release steps finished ===" >&2
}

main() {
  cyan "NextPressKit — interactive deploy"
  echo "" >&2

  local os_kind
  os_kind="$(detect_os)"
  case "$os_kind" in
    linux)   yellow "Detected: Linux" ;;
    darwin)  yellow "Detected: macOS" ;;
    windows) yellow "Detected: Windows-like (Git Bash)" ;;
    *)       yellow "Detected: unknown OS" ;;
  esac
  echo "" >&2

  echo "Environment tier:" >&2
  echo "  1) production  2) staging  3) dev  4) local" >&2
  local tier_choice
  tier_choice="$(prompt "4" "Choose tier (1-4 or name)")"
  local tier="local"
  case "$(echo "$tier_choice" | tr '[:upper:]' '[:lower:]')" in
    1|production) tier="production" ;;
    2|staging) tier="staging" ;;
    3|dev) tier="dev" ;;
    4|local) tier="local" ;;
    *) tier="local" ;;
  esac

  local default_domain="api.example.com"
  local default_port="9090"
  case "$tier" in
    production) default_domain="api.example.com"; default_port="9090" ;;
    staging)    default_domain="api-staging.example.com"; default_port="9091" ;;
    dev)        default_domain="api-dev.example.com"; default_port="9092" ;;
    local)      default_domain="localhost"; default_port="9090" ;;
  esac

  local gen_config
  gen_config="$(prompt_yn y "Generate Nginx (+ optional systemd) config files?")"

  local server_name="$default_domain"
  local deploy_dir="$ROOT_DIR"
  local app_port="$default_port"
  local listen_port="80"
  local include_systemd="n"
  local run_user="www-data"
  local run_group="www-data"
  local ssl_mode="none"
  local certbot_email="admin@example.com"
  local ssl_cert=""
  local ssl_key=""
  local listen_ssl="443"
  local redirect_http="y"

  if [[ "$gen_config" == "y" ]]; then
    server_name="$(prompt "$default_domain" "Nginx server_name (public hostname)")"
    default_deploy="/var/www/nextpress-backend-${tier}"
    if [[ "$os_kind" == "darwin" || "$tier" == "local" ]]; then
      default_deploy="$ROOT_DIR"
    fi
    deploy_dir="$(prompt "$default_deploy" "Absolute app root (uploads alias, systemd WorkingDirectory)")"
    app_port="$(prompt "$default_port" "APP_PORT (Go listens here)")"
    listen_port="$(prompt "$([[ "$tier" == "local" ]] && echo "8080" || echo "80")" "Nginx HTTP listen port")"

    cyan "TLS / SSL for Nginx config:" >&2
    echo "  1) none (HTTP only)  2) Let's Encrypt (HTTP vhost + Certbot instructions)" >&2
    echo "  3) HTTPS with PEM files (mkcert, internal CA, or commercial cert)" >&2
    local ssl_pick
    ssl_pick="$(prompt "1" "Choose (1-3)")"
    case "$(echo "$ssl_pick" | tr -d '[:space:]')" in
      2)
        ssl_mode="letsencrypt"
        certbot_email="$(prompt "$certbot_email" "Email for Let's Encrypt (Certbot)")"
        ;;
      3)
        ssl_mode="pem"
        ssl_cert="$(prompt "${HOME}/.local/share/nextpress-ssl/cert.pem" "Path to fullchain / certificate PEM")"
        ssl_key="$(prompt "${HOME}/.local/share/nextpress-ssl/key.pem" "Path to private key PEM")"
        listen_ssl="$(prompt "443" "Nginx HTTPS listen port")"
        redirect_http="$(prompt_yn y "Add HTTP→HTTPS redirect on port ${listen_port}?")"
        ;;
      *)
        ssl_mode="none"
        ;;
    esac

    include_systemd="n"
    if [[ "$os_kind" == "linux" && "$tier" != "local" ]]; then
      include_systemd="$(prompt_yn y "Generate systemd unit file?")"
    elif [[ "$os_kind" == "linux" && "$tier" == "local" ]]; then
      include_systemd="$(prompt_yn n "Generate systemd unit? (optional on Ubuntu laptop)")"
    fi

    run_user="www-data"
    run_group="www-data"
    if [[ "$os_kind" == "darwin" || "$tier" == "local" ]]; then
      run_user="${SUDO_USER:-$USER}"
      run_group="$(id -gn "$run_user" 2>/dev/null || echo staff)"
    fi
    if [[ "$include_systemd" == "y" ]]; then
      run_user="$(prompt "$run_user" "systemd User")"
      run_group="$(prompt "$run_group" "systemd Group")"
    fi
  fi

  local slug
  slug="$(slugify "${tier}-${server_name}")"
  [[ -z "$slug" ]] && slug="${tier}-site"
  local gen_dir="$ROOT_DIR/deploy/generated/${slug}"
  mkdir -p "$gen_dir"

  if [[ "$gen_config" == "y" ]]; then
    local nginx_out="$gen_dir/nginx-nextpress-${tier}.conf"
    case "$ssl_mode" in
      none|letsencrypt)
        write_nginx_http "$nginx_out" "$server_name" "$listen_port" "$app_port" "$deploy_dir" "$tier"
        ;;
      pem)
        write_nginx_https "$nginx_out" "$server_name" "$listen_port" "$listen_ssl" "$app_port" "$deploy_dir" "$tier" "$ssl_cert" "$ssl_key" "$redirect_http"
        ;;
    esac

    if [[ "$include_systemd" == "y" ]]; then
      write_systemd "$gen_dir/nextpress-backend@${tier}.service" "$tier" "$deploy_dir" "$run_user" "$run_group"
    else
      yellow "No systemd unit generated." >&2
    fi

    write_readme "$gen_dir/README.md" "$os_kind" "$tier" "$deploy_dir" "$gen_dir" "$ssl_mode" "$server_name" "$certbot_email"
    green "Wrote config under: $gen_dir" >&2

    if [[ "$ssl_mode" == "letsencrypt" ]] && [[ "$os_kind" == "linux" ]]; then
      if [[ "$(prompt_yn n "Run certbot --nginx now? (needs sudo, DNS must point here)")" == "y" ]]; then
        if command -v certbot >/dev/null 2>&1; then
          sudo certbot --nginx -d "$server_name" --email "$certbot_email" --agree-tos
        else
          red "certbot not found. Install: sudo apt install certbot python3-certbot-nginx"
        fi
      fi
    fi

    if [[ "$os_kind" == "linux" && "$(id -u)" -ne 0 ]]; then
      if [[ "$(prompt_yn n "Copy Nginx (+ systemd if any) into /etc now? (sudo)")" == "y" ]]; then
        sudo cp "$gen_dir/nginx-nextpress-${tier}.conf" "/etc/nginx/sites-available/nextpress-backend-${tier}.conf"
        sudo ln -sf "/etc/nginx/sites-available/nextpress-backend-${tier}.conf" /etc/nginx/sites-enabled/
        sudo nginx -t
        sudo systemctl reload nginx
        if [[ "$include_systemd" == "y" && -f "$gen_dir/nextpress-backend@${tier}.service" ]]; then
          sudo cp "$gen_dir/nextpress-backend@${tier}.service" "/etc/systemd/system/nextpress-backend@${tier}.service"
          sudo systemctl daemon-reload
          yellow "Enable: sudo systemctl enable --now nextpress-backend@${tier}" >&2
        fi
      fi
    elif [[ "$os_kind" == "linux" && "$(id -u)" -eq 0 ]]; then
      yellow "Running as root: install paths manually if needed." >&2
    fi
  else
    yellow "Skipped config generation." >&2
  fi

  if [[ "$(prompt_yn y "Run release pipeline here (build, migrate, optional seed, restart service)?")" == "y" ]]; then
    run_release_pipeline "$tier"
  else
    if [[ "$gen_config" == "y" ]]; then
      cyan "Skipped release. See ${gen_dir}/README.md for generated configs." >&2
    else
      cyan "Skipped release." >&2
    fi
  fi

  green "Done." >&2
}

main "$@"
