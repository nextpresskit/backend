#!/usr/bin/env bash
# Deploy wizard for NextPressKit: Nginx (+ optional TLS), systemd snippets,
# and optional release (git pull, build, migrate, seed, service restart).
#
# Interactive (from repo root):   ./scripts/deploy
# Install Nginx from defaults:     ./scripts/deploy apply-nginx [--http-only] ...
# Same via nextpresskit / make:     ./scripts/nextpresskit deploy-apply-nginx   /   make deploy-nginx
#
# Generated output: deploy/generated/<slug>/

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

load_root_env() {
  if [[ -f "$ROOT_DIR/.env" ]]; then
    set -a
    # shellcheck source=/dev/null
    source "$ROOT_DIR/.env"
    set +a
  fi
}

cyan()  { printf '\033[36m%s\033[0m\n' "$*" >&2; }
green() { printf '\033[32m%s\033[0m\n' "$*" >&2; }
yellow(){ printf '\033[33m%s\033[0m\n' "$*" >&2; }
red()   { printf '\033[31m%s\033[0m\n' "$*" >&2; }

detect_os() {
  case "$(uname -s 2>/dev/null)" in
    Linux*)   echo "linux" ;;
    Darwin*)  echo "darwin" ;;
    MINGW*|MSYS*|CYGWIN*) echo "windows" ;;
    *)        echo "unknown" ;;
  esac
}

tier_to_branch() {
  case "$1" in
    production) echo "main" ;;
    staging)    echo "staging" ;;
    dev)        echo "dev" ;;
    *)          echo "" ;;
  esac
}

prompt() {
  local _default="$1"
  local _text="$2"
  local _line
  read -r -p "${_text} [${_default}]: " _line || true
  if [[ -z "${_line// }" ]]; then
    echo "$_default"
  else
    echo "$_line"
  fi
}

prompt_yn() {
  local _default="$1"
  local _text="$2"
  local _line
  while true; do
    read -r -p "${_text} (y/n) [${_default}]: " _line || true
    _line="${_line:-$_default}"
    case "${_line:0:1}" in
      y|Y) echo y; return 0 ;;
      n|N) echo n; return 0 ;;
    esac
    yellow "Please answer y or n."
  done
}

slugify() {
  echo "$1" | tr '[:upper:]' '[:lower:]' | sed -e 's/[^a-z0-9._-]\+/-/g' -e 's/^-\|-$//g' | cut -c1-48
}

# True if $1 appears as a hostname on any non-comment line in $2 (readable hosts file).
host_in_hosts_file() {
  local host="$1"
  local file="$2"
  [[ -r "$file" ]] || return 1
  local line ip rest
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "${line// }" ]] && continue
    read -r ip rest <<<"$line" || continue
    [[ -z "$rest" ]] && continue
    local c
    for c in $rest; do
      if [[ "$c" == "$host" ]]; then
        return 0
      fi
    done
  done <"$file"
  return 1
}

# Skip tokens that should not get a loopback /etc/hosts entry.
_should_skip_hosts_token() {
  local t="$1"
  local low
  low="$(echo "$t" | tr '[:upper:]' '[:lower:]')"
  [[ -z "$t" ]] && return 0
  [[ "$low" == "localhost" ]] && return 0
  if [[ "$t" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then return 0; fi
  [[ "$t" == "::1" ]] && return 0
  return 1
}

# True if any server_name token would benefit from /etc/hosts (non-localhost hostname).
_needs_hosts_entry() {
  local names="$1"
  local t
  for t in $names; do
    t="${t//,/}"
    t="${t//;/}"
    if _should_skip_hosts_token "$t"; then
      continue
    fi
    return 0
  done
  return 1
}

# Append 127.0.0.1 lines for each Nginx server_name token that is not yet in hosts.
ensure_hosts_entries() {
  local ip="$1"
  local server_names="$2"
  local hosts_file="/etc/hosts"

  local t
  for t in $server_names; do
    t="${t//,/}"
    t="${t//;/}"
    [[ -z "$t" ]] && continue
    if _should_skip_hosts_token "$t"; then
      continue
    fi
    if host_in_hosts_file "$t" "$hosts_file"; then
      green "${t} already listed in ${hosts_file}" >&2
      continue
    fi
    yellow "Adding ${ip} ${t} to ${hosts_file} (sudo)..." >&2
    if printf '%s\t%s\n' "$ip" "$t" | sudo tee -a "$hosts_file" >/dev/null; then
      green "Added ${t} → ${ip}" >&2
    else
      red "Could not write ${hosts_file}. Add manually: ${ip} ${t}"
      return 1
    fi
  done
  return 0
}

# HTTP-only Nginx server block
write_nginx_http() {
  local out="$1"
  local server_name="$2"
  local listen_port="$3"
  local app_port="$4"
  local deploy_dir="$5"
  local tier="$6"
  local gen_label="${APP_NAME:-NextPressKit}"

  cat >"$out" <<EOF
# Generated by scripts/deploy — ${gen_label} Nginx (${tier}, HTTP)
# After edits: sudo nginx -t && sudo systemctl reload nginx   (Linux)
#              "\$(brew --prefix nginx)/bin/nginx" -t && brew services restart nginx   (macOS)

server {
    listen ${listen_port};
    server_name ${server_name};

    location /uploads/ {
        alias ${deploy_dir}/storage/uploads/;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
    }

    location / {
        proxy_pass         http://127.0.0.1:${app_port};
        proxy_set_header   Host \$host;
        proxy_set_header   X-Real-IP \$remote_addr;
        proxy_set_header   X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
    }
}
EOF
}

# HTTPS Nginx: optional HTTP→HTTPS redirect + TLS server
write_nginx_https() {
  local out="$1"
  local server_name="$2"
  local listen_http="$3"
  local listen_ssl="$4"
  local app_port="$5"
  local deploy_dir="$6"
  local tier="$7"
  local cert="$8"
  local key="$9"
  local redirect_http="${10:-y}"
  local gen_label="${APP_NAME:-NextPressKit}"

  {
    if [[ "$redirect_http" == "y" ]]; then
      cat <<EOF
# Generated by scripts/deploy — ${gen_label} Nginx (${tier}, HTTPS)
server {
    listen ${listen_http};
    server_name ${server_name};
    return 301 https://\$host\$request_uri;
}

EOF
    fi
    cat <<EOF
server {
    listen ${listen_ssl} ssl http2;
    server_name ${server_name};

    ssl_certificate     ${cert};
    ssl_certificate_key ${key};

    location /uploads/ {
        alias ${deploy_dir}/storage/uploads/;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
    }

    location / {
        proxy_pass         http://127.0.0.1:${app_port};
        proxy_set_header   Host \$host;
        proxy_set_header   X-Real-IP \$remote_addr;
        proxy_set_header   X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto \$scheme;
    }
}
EOF
  } >"$out"
}

write_systemd() {
  local out="$1"
  local tier="$2"
  local deploy_dir="$3"
  local run_user="$4"
  local run_group="$5"
  local gen_label="${APP_NAME:-NextPressKit}"
  local su="${APP_SERVICE_UNIT:-nextpresskit-backend}"

  cat >"$out" <<EOF
# Generated by scripts/deploy — ${gen_label} systemd (${tier})
#   sudo cp ${su}@${tier}.service /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now ${su}@${tier}

[Unit]
Description=${gen_label} (${tier})
After=network.target

[Service]
Type=simple
WorkingDirectory=${deploy_dir}
Environment=APP_ENV=${tier}
EnvironmentFile=${deploy_dir}/.env
ExecStart=${deploy_dir}/bin/server
Restart=always
RestartSec=5
User=${run_user}
Group=${run_group}

[Install]
WantedBy=multi-user.target
EOF
}

write_readme() {
  local out="$1"
  local os_kind="$2"
  local tier="$3"
  local deploy_dir="$4"
  local gen_dir="$5"
  local ssl_mode="$6"
  local server_name="$7"
  local certbot_email="$8"
  local gen_label="${APP_NAME:-NextPressKit}"
  local su="${APP_SERVICE_UNIT:-nextpresskit-backend}"

  cat >"$out" <<EOF
# Generated ${gen_label} deploy snippets

- **Tier:** ${tier}
- **App root:** ${deploy_dir}
- **TLS mode:** ${ssl_mode}
- **Files:**
  - \`nginx-${su}-${tier}.conf\`
  - \`${su}@${tier}.service\` (if generated)

## TLS notes

EOF

  case "$ssl_mode" in
    letsencrypt)
      cat >>"$out" <<EOF
**Let's Encrypt:** HTTP vhost is in the generated config (port 80). After installing the site:

\`\`\`bash
sudo apt install -y certbot python3-certbot-nginx
sudo certbot --nginx -d ${server_name} --email ${certbot_email} --agree-tos --non-interactive
\`\`\`

Omit \`--non-interactive\` for the first run if you prefer prompts. Then \`sudo nginx -t && sudo systemctl reload nginx\`.

EOF
      ;;
    pem)
      cat >>"$out" <<EOF
**HTTPS (PEM):** Paths are in \`nginx-${su}-${tier}.conf\`. Renew or replace certificates before expiry, then \`nginx -t\` and reload.

EOF
      ;;
    *)
      cat >>"$out" <<EOF
**HTTP only:** Add TLS later with Certbot (\`docs/DEPLOYMENT.md\`) or mkcert locally (\`docs/deployment/local.md\`).

EOF
      ;;
  esac

  cat >>"$out" <<EOF
## App setup

1. \`.env\` in \`${deploy_dir}\` with \`APP_PORT\`, \`DB_*\`, \`JWT_SECRET\`, and \`APP_ENV\` (systemd sets \`APP_ENV=${tier}\` when enabled).
2. \`make build\` in \`${deploy_dir}\`.

EOF

  if [[ "$os_kind" == "linux" ]]; then
    cat >>"$out" <<EOF
### Ubuntu / Debian

\`\`\`bash
sudo cp ${gen_dir}/nginx-${su}-${tier}.conf /etc/nginx/sites-available/${su}-${tier}.conf
sudo ln -sf /etc/nginx/sites-available/${su}-${tier}.conf /etc/nginx/sites-enabled/
sudo nginx -t && sudo systemctl reload nginx
# If you generated a unit:
sudo cp ${gen_dir}/${su}@${tier}.service /etc/systemd/system/
sudo systemctl daemon-reload
sudo systemctl enable --now ${su}@${tier}
\`\`\`

EOF
  elif [[ "$os_kind" == "darwin" ]]; then
    local brew_nginx
    brew_nginx="$(brew --prefix nginx 2>/dev/null || echo "/opt/homebrew/opt/nginx")"
    cat >>"$out" <<EOF
### macOS (Homebrew Nginx)

Include \`nginx-${su}-${tier}.conf\` from \`$(brew --prefix 2>/dev/null || echo /opt/homebrew)/etc/nginx/nginx.conf\` (or \`servers/*\`).

\`\`\`bash
"${brew_nginx}/bin/nginx" -t && brew services restart nginx
\`\`\`

EOF
  else
    cat >>"$out" <<EOF
### Windows / Git Bash

Use \`scripts/deploy.ps1\` in PowerShell, or merge the \`server\` blocks into your Nginx config.

EOF
  fi
}

run_release_pipeline() {
  local tier="$1"
  local branch
  branch="$(tier_to_branch "$tier")"

  if ! command -v go >/dev/null 2>&1; then
    red "Go is not installed. Skipping release build."
    return 1
  fi

  if [[ ! -f .env ]]; then
    red ".env not found in ${ROOT_DIR}. Create it before release."
    return 1
  fi

  if [[ -n "$branch" ]] && [[ -d .git ]]; then
    if [[ "$(prompt_yn y "Git: fetch/checkout/pull branch '${branch}'?")" == "y" ]]; then
      green "=== Git: ${branch} ===" >&2
      git fetch origin
      git checkout "$branch"
      git pull origin "$branch"
    fi
  elif [[ -n "$branch" ]]; then
    yellow "Not a git repository; skipping git pull." >&2
  else
    yellow "Tier '${tier}': skipping git (no mapped branch for local)." >&2
  fi

  green "=== Building binaries ===" >&2
  go env -w CGO_ENABLED=0 >/dev/null 2>&1 || true
  go mod download
  mkdir -p bin
  go build -v -o bin/server ./cmd/api
  go build -v -o bin/migrate ./cmd/migrate
  go build -v -o bin/seed ./cmd/seed

  green "=== Migrations ===" >&2
  set -a
  # shellcheck source=/dev/null
  source .env
  set +a
  ./bin/migrate -command=up

  if [[ "${RUN_SEED_ON_DEPLOY:-}" == "true" ]]; then
    green "=== Seed (RUN_SEED_ON_DEPLOY=true) ===" >&2
    ./bin/seed
  elif [[ "$(prompt_yn n "Run database seeders now?")" == "y" ]]; then
    green "=== Seed ===" >&2
    ./bin/seed
  else
    yellow "Seed skipped." >&2
  fi

  local su="${APP_SERVICE_UNIT:-nextpresskit-backend}"
  local svc="${su}@${tier}"
  if [[ "$tier" != "local" ]] && command -v systemctl >/dev/null 2>&1; then
    if systemctl list-units --type=service 2>/dev/null | grep -qF "$svc"; then
      if [[ "$(prompt_yn y "Restart systemd service ${svc}?")" == "y" ]]; then
        green "=== systemctl restart ${svc} ===" >&2
        sudo systemctl restart "$svc"
        sudo systemctl status "$svc" --no-pager || true
      fi
    else
      yellow "systemd unit '${svc}' not active. Start manually: sudo systemctl enable --now ${svc}" >&2
    fi
  elif [[ "$tier" == "local" ]]; then
    yellow "Local tier: restart the API yourself (make run / make start)." >&2
  fi

  green "=== Release steps finished ===" >&2
}

apply_nginx_usage() {
  cat <<'EOF'
Usage: ./scripts/deploy apply-nginx [options]

Regenerates the Nginx site from this repo and, on Linux, installs it under
/etc/nginx/sites-available, symlinks sites-enabled, runs nginx -t, and reloads
nginx (unless --dry-run or --no-reload). On macOS only the generated file is
written; copy or include it into your Homebrew nginx layout manually.

Options:
  --http-only           HTTP only (no TLS). Skips the interactive TLS menu when used from a TTY.
  --letsencrypt         Certbot / Let's Encrypt (same as interactive option 3). Skips the TLS
                        menu. HTTP on port 80, installs certbot if missing (Linux: apt or dnf),
                        then certbot --nginx. Prompts for ACME email and LE terms (unless
                        CERTBOT_EMAIL is set). Needs a public DNS name (not typical for *.local).
                        Incompatible with --http-only, file --cert/--key.
  --tier T              local (default), dev, staging, production
  --server-name HOST    Override server_name (else NEXTPRESS_PUBLIC_HOST from .env, else tier defaults)
  --app-port N          proxy_pass port (default: APP_PORT from .env, else 9090)
  --listen-http PORT    HTTP port (default: 8080 for local|dev, 80 otherwise; forced to 80 with
                        --letsencrypt)
  --listen-ssl PORT     HTTPS port when using TLS (default: 443); ignored with --http-only
  --cert PATH           PEM cert file, or the word letsencrypt|auto (same as --letsencrypt)
  --key PATH            PEM key (default: NEXTPRESS_SSL_KEY or $XDG_DATA_HOME/<APP_LOCAL_SSL_SUBDIR>/key.pem; subdir default nextpresskit-ssl)
  --no-reload           After nginx -t, do not systemctl reload nginx
  --no-tls-menu         Skip the interactive TLS menu (used by ./scripts/setup-local-https.sh).
                        If default PEM paths are missing, falls back to HTTP-only instead of erroring.
  --dry-run             Print install commands only; still writes generated config

From a terminal, with no --http-only / --letsencrypt / --cert / --key flags, you
get a short menu: HTTPS (PEM paths), HTTP-only, or Let's Encrypt.

If stdin is not a TTY and default PEM paths are missing, apply-nginx falls back
to HTTP-only (see docs/deployment/local.md for mkcert / HTTPS in the browser).

Examples:
  ./scripts/deploy apply-nginx
  ./scripts/deploy apply-nginx --http-only
  ./scripts/deploy apply-nginx --letsencrypt --server-name api.example.com
  make deploy-nginx
EOF
}

# Install certbot + nginx plugin on Linux (apt or dnf) if certbot is not on PATH.
ensure_certbot_linux() {
  if command -v certbot >/dev/null 2>&1; then
    green "certbot is already installed." >&2
    return 0
  fi
  green "Installing certbot and python3-certbot-nginx (sudo)…" >&2
  if command -v apt-get >/dev/null 2>&1; then
    sudo DEBIAN_FRONTEND=noninteractive apt-get update -qq
    sudo DEBIAN_FRONTEND=noninteractive apt-get install -y certbot python3-certbot-nginx
    return 0
  fi
  if command -v dnf >/dev/null 2>&1; then
    sudo dnf install -y certbot python3-certbot-nginx
    return 0
  fi
  red "Neither apt-get nor dnf found. Install certbot and the nginx plugin for your OS, then re-run."
  return 1
}

# Echo ACME contact email: use CERTBOT_EMAIL if set, else prompt (TTY required).
apply_nginx_resolve_certbot_email() {
  local val="${CERTBOT_EMAIL:-}"
  val="${val#"${val%%[![:space:]]*}"}"
  val="${val%"${val##*[![:space:]]}"}"
  if [[ -n "$val" ]]; then
    green "Using CERTBOT_EMAIL from the environment." >&2
    printf '%s\n' "$val"
    return 0
  fi
  if [[ ! -t 0 ]]; then
    red "Let's Encrypt: stdin is not a TTY and CERTBOT_EMAIL is unset; cannot prompt for email." >&2
    return 1
  fi
  cyan "Let's Encrypt needs an email for your ACME account (renewal notices, lost key recovery)." >&2
  local line=""
  while [[ -z "${line// }" ]]; do
    read -r -p "Email for Let's Encrypt / ACME: " line || return 1
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    if [[ -z "$line" ]]; then
      yellow "Email cannot be empty."
    fi
  done
  printf '%s\n' "$line"
  return 0
}

# When stdin is a TTY, ask before running Certbot.
apply_nginx_prompt_letsencrypt_confirm() {
  local sn="$1"
  [[ -t 0 ]] || return 0
  local ans
  read -r -p "Request a Let's Encrypt certificate for Nginx server_name '${sn}'? (Y/n): " ans || return 1
  ans="${ans:-Y}"
  case "${ans:0:1}" in
    y|Y) return 0 ;;
    *)
      red "Aborted."
      return 1
      ;;
  esac
}

apply_nginx_prompt_letsencrypt_tos() {
  [[ -t 0 ]] || return 0
  local a
  read -r -p "Agree to the Let's Encrypt Terms of Service (https://letsencrypt.org/repository/)? (y/N): " a || return 1
  case "${a:0:1}" in
    y|Y) return 0 ;;
    *)
      red "Aborted (certbot requires accepting the subscriber agreement)."
      return 1
      ;;
  esac
}

# Loop until PEM files exist or user switches to HTTP-only / aborts. Updates ssl_cert, ssl_key,
# and may set http_only=1 in caller scope.
apply_nginx_prompt_pem_paths_until_ok() {
  local pc pk again
  while true; do
    cyan "PEM paths (press Enter to keep the value in brackets):" >&2
    read -r -p "Certificate PEM [${ssl_cert}]: " pc || return 1
    pc="${pc#"${pc%%[![:space:]]*}"}"
    pc="${pc%"${pc##*[![:space:]]}"}"
    [[ -n "$pc" ]] && ssl_cert="$pc"
    read -r -p "Private key PEM [${ssl_key}]: " pk || return 1
    pk="${pk#"${pk%%[![:space:]]*}"}"
    pk="${pk%"${pk##*[![:space:]]}"}"
    [[ -n "$pk" ]] && ssl_key="$pk"

    if [[ -f "$ssl_cert" && -r "$ssl_cert" && -f "$ssl_key" && -r "$ssl_key" ]]; then
      green "Using certificate: ${ssl_cert}" >&2
      green "Using private key:   ${ssl_key}" >&2
      return 0
    fi
    yellow "Those files are missing or not readable." >&2
    read -r -p "Try different paths? (Y/n): " again || return 1
    again="${again:-Y}"
    case "${again:0:1}" in
      n|N)
        read -r -p "Use HTTP-only instead (no TLS)? (y/N): " again || return 1
        case "${again:0:1}" in
          y|Y)
            http_only=1
            yellow "Continuing with HTTP-only." >&2
            return 0
            ;;
          *)
            red "Aborted."
            return 1
            ;;
        esac
        ;;
    esac
  done
}

# TTY + no SSL-related flags: choose HTTPS (PEM), HTTP-only, or Let's Encrypt.
apply_nginx_prompt_tls_interactive_menu() {
  [[ "${skip_tls_menu:-0}" -eq 1 ]] && return 0
  [[ "${NEXTPRESS_SKIP_TLS_MENU:-}" == "1" ]] && return 0
  [[ -t 0 ]] || return 0
  [[ "$http_only" -eq 1 ]] && return 0
  [[ "$use_letsencrypt" -eq 1 ]] && return 0
  [[ "$cert_explicit" -eq 1 || "$key_explicit" -eq 1 ]] && return 0

  local hint_def=2
  if [[ -f "$ssl_cert" && -f "$ssl_key" ]]; then
    hint_def=1
  fi

  cyan "TLS for this Nginx site (server_name: ${server_name})" >&2
  echo "  1) HTTPS — PEM certificate + private key (e.g. mkcert)" >&2
  echo "  2) HTTP only — no TLS" >&2
  echo "  3) Let's Encrypt — Certbot (public DNS, port 80; automated on Linux)" >&2
  local pick
  read -r -p "Choose 1-3 [${hint_def}]: " pick || return 1
  pick="${pick:-$hint_def}"
  pick="$(echo "$pick" | tr -d '[:space:]')"
  case "$pick" in
    1)
      if ! apply_nginx_prompt_pem_paths_until_ok; then
        return 1
      fi
      ;;
    2)
      http_only=1
      ;;
    3)
      use_letsencrypt=1
      listen_http="80"
      ;;
    *)
      red "Invalid choice (enter 1, 2, or 3)."
      return 1
      ;;
  esac
  return 0
}

# After CLI or menu may have enabled Let's Encrypt: OS check, listen 80, .local hint.
apply_nginx_apply_letsencrypt_listen_and_warn() {
  [[ "$use_letsencrypt" -eq 1 ]] || return 0
  listen_http="80"
  case "$server_name" in
    *.local)
      yellow "Note: Let's Encrypt cannot issue publicly trusted certs for most *.local names; use mkcert + option 1 for local dev." >&2
      ;;
  esac
  return 0
}

# Non-interactive: write Nginx config and install on Linux (sudo).
apply_nginx_cli() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    apply_nginx_usage
    return 0
  fi

  local tier="local"
  local http_only=0
  local server_name=""
  local app_port=""
  local listen_http=""
  local listen_ssl="443"
  local ssl_cert=""
  local ssl_key=""
  local no_reload=0
  local dry_run=0
  local cert_explicit=0
  local key_explicit=0
  local use_letsencrypt=0
  local skip_tls_menu=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --http-only)       http_only=1; shift ;;
      --letsencrypt)     use_letsencrypt=1; shift ;;
      --no-tls-menu)     skip_tls_menu=1; shift ;;
      --tier)            tier="$2"; shift 2 ;;
      --server-name)     server_name="$2"; shift 2 ;;
      --app-port)        app_port="$2"; shift 2 ;;
      --listen-http)     listen_http="$2"; shift 2 ;;
      --listen-ssl)      listen_ssl="$2"; shift 2 ;;
      --cert)
        case "$2" in
          letsencrypt|auto)
            use_letsencrypt=1
            ;;
          *)
            ssl_cert="$2"
            cert_explicit=1
            ;;
        esac
        shift 2
        ;;
      --key)             ssl_key="$2"; key_explicit=1; shift 2 ;;
      --no-reload)       no_reload=1; shift ;;
      --dry-run)         dry_run=1; shift ;;
      -h|--help)         apply_nginx_usage; return 0 ;;
      *)
        red "Unknown option: $1"
        apply_nginx_usage
        return 1
        ;;
    esac
  done

  case "$(echo "$tier" | tr '[:upper:]' '[:lower:]')" in
    local)     tier="local" ;;
    dev)       tier="dev" ;;
    staging)   tier="staging" ;;
    production) tier="production" ;;
    *)
      red "Invalid --tier: $tier"
      return 1
      ;;
  esac

  load_root_env
  local service_unit="${APP_SERVICE_UNIT:-nextpresskit-backend}"
  local ssl_subdir="${APP_LOCAL_SSL_SUBDIR:-nextpresskit-ssl}"
  local ssl_dir_default="${XDG_DATA_HOME:-"$HOME/.local/share"}/${ssl_subdir}"

  if [[ -z "$server_name" ]]; then
    if [[ -n "${NEXTPRESS_PUBLIC_HOST:-}" ]]; then
      server_name="${NEXTPRESS_PUBLIC_HOST}"
    else
      case "$tier" in
        production) server_name="api.example.com" ;;
        staging)    server_name="api-staging.example.com" ;;
        dev)        server_name="api-dev.example.com" ;;
        local)      server_name="nextpresskit.local" ;;
      esac
    fi
  fi

  if [[ "$cert_explicit" -eq 0 ]]; then
    ssl_cert="${NEXTPRESS_SSL_CERT:-$ssl_dir_default/cert.pem}"
  fi
  if [[ "$key_explicit" -eq 0 ]]; then
    ssl_key="${NEXTPRESS_SSL_KEY:-$ssl_dir_default/key.pem}"
  fi
  if [[ -z "$app_port" ]]; then
    app_port="${APP_PORT:-9090}"
  fi

  local os_kind
  os_kind="$(detect_os)"

  if [[ -z "$listen_http" ]]; then
    case "$tier" in
      local|dev) listen_http="8080" ;;
      *)         listen_http="80" ;;
    esac
  fi

  if ! apply_nginx_prompt_tls_interactive_menu; then
    return 1
  fi

  if [[ "$use_letsencrypt" -eq 1 ]]; then
    if [[ "$http_only" -eq 1 ]]; then
      red "Do not combine --letsencrypt (or --cert letsencrypt|auto) with --http-only."
      return 1
    fi
    if [[ "$cert_explicit" -eq 1 ]]; then
      red "Do not pass a PEM file path in --cert together with --letsencrypt; use --cert letsencrypt|auto or --letsencrypt alone."
      return 1
    fi
    if [[ "$key_explicit" -eq 1 ]]; then
      red "Do not pass --key with --letsencrypt; Certbot installs certificate and key."
      return 1
    fi
    if [[ "$os_kind" != "linux" ]]; then
      red "Let's Encrypt (Certbot) is only automated on Linux (apt/dnf). Use mkcert + HTTPS option 1, or install certbot manually."
      return 1
    fi
  fi
  apply_nginx_apply_letsencrypt_listen_and_warn

  if [[ "$use_letsencrypt" -eq 0 && "$http_only" -eq 0 ]]; then
    if [[ ! -f "$ssl_cert" || ! -f "$ssl_key" ]]; then
      if [[ "$cert_explicit" -eq 1 || "$key_explicit" -eq 1 ]]; then
        red "TLS files not found (cert: $ssl_cert, key: $ssl_key)."
        yellow "Fix paths or use flags: --http-only / --letsencrypt / --cert / --key."
        return 1
      fi
      if [[ -t 0 ]]; then
        if [[ "$skip_tls_menu" -eq 1 ]] || [[ "${NEXTPRESS_SKIP_TLS_MENU:-}" == "1" ]]; then
          yellow "TLS PEM files missing; using HTTP-only (--no-tls-menu)." >&2
          http_only=1
        else
          red "TLS PEM files are still missing after the interactive prompts."
          return 1
        fi
      fi
      yellow "TLS files not found at default paths; using HTTP-only for this run." >&2
      yellow "For HTTPS: mkcert (see docs/deployment/local.md), or run apply-nginx from a terminal for prompts." >&2
      http_only=1
    fi
  fi

  local slug
  slug="$(slugify "${tier}-${server_name}")"
  [[ -z "$slug" ]] && slug="${tier}-site"
  local gen_dir="$ROOT_DIR/deploy/generated/${slug}"
  mkdir -p "$gen_dir"
  local nginx_out="$gen_dir/nginx-${service_unit}-${tier}.conf"

  if [[ "$use_letsencrypt" -eq 1 ]]; then
    write_nginx_http "$nginx_out" "$server_name" "80" "$app_port" "$ROOT_DIR" "$tier"
    cyan "Wrote HTTP Nginx config for Certbot (listen 80): $nginx_out" >&2
  elif [[ "$http_only" -eq 1 ]]; then
    write_nginx_http "$nginx_out" "$server_name" "$listen_http" "$app_port" "$ROOT_DIR" "$tier"
    cyan "Wrote HTTP-only Nginx config: $nginx_out" >&2
  else
    write_nginx_https "$nginx_out" "$server_name" "$listen_http" "$listen_ssl" "$app_port" "$ROOT_DIR" "$tier" "$ssl_cert" "$ssl_key" "y"
    cyan "Wrote HTTPS Nginx config: $nginx_out" >&2
  fi

  if [[ "$os_kind" == "linux" ]]; then
    local dest="/etc/nginx/sites-available/${service_unit}-${tier}.conf"
    local link="/etc/nginx/sites-enabled/${service_unit}-${tier}.conf"
    if [[ "$dry_run" -eq 1 ]]; then
      yellow "Dry-run: would sudo cp $nginx_out $dest" >&2
      yellow "Dry-run: would sudo ln -sf $dest $link" >&2
      yellow "Dry-run: would sudo nginx -t && (reload unless --no-reload)" >&2
      if [[ "$use_letsencrypt" -eq 1 ]]; then
        yellow "Dry-run: would install certbot if missing, then: sudo certbot --nginx -d ${server_name} ..." >&2
      fi
      green "Generated file is at: $nginx_out" >&2
      return 0
    fi
    green "Installing Nginx site (sudo)…" >&2
    sudo cp "$nginx_out" "$dest"
    sudo ln -sf "$dest" "$link"
    if ! sudo nginx -t; then
      red "nginx -t failed. Fix other sites or paths, then reload nginx manually."
      return 1
    fi
    if [[ "$no_reload" -eq 0 ]]; then
      sudo systemctl reload nginx
      green "nginx reloaded." >&2
    else
      yellow "Skipped reload (--no-reload). Run: sudo systemctl reload nginx" >&2
    fi

    if [[ "$use_letsencrypt" -eq 1 ]]; then
      if ! apply_nginx_prompt_letsencrypt_confirm "$server_name"; then
        return 1
      fi
      local certbot_email
      certbot_email="$(apply_nginx_resolve_certbot_email)" || return 1
      if ! apply_nginx_prompt_letsencrypt_tos; then
        return 1
      fi
      if ! ensure_certbot_linux; then
        return 1
      fi
      yellow "Running certbot for ${server_name} …" >&2
      if ! sudo certbot --nginx -d "$server_name" --email "$certbot_email" --agree-tos --non-interactive --redirect; then
        red "certbot failed. Needs a public hostname, DNS pointing to this host, and port 80 reachable from the internet."
        return 1
      fi
      green "certbot finished (nginx config may have been updated in place)." >&2
    fi
  elif [[ "$os_kind" == "darwin" ]]; then
    yellow "macOS: install the file manually, for example:" >&2
    echo "  sudo cp \"$nginx_out\" /opt/homebrew/etc/nginx/servers/${service_unit}-${tier}.conf" >&2
    echo "  # or include from nginx.conf, then: brew services restart nginx" >&2
  else
    yellow "Generated: $nginx_out — copy into your Nginx config (OS: $os_kind)." >&2
  fi

  green "Done. server_name=${server_name} → 127.0.0.1:${app_port}" >&2
}

main() {
  load_root_env
  local gen_label="${APP_NAME:-NextPressKit}"
  cyan "${gen_label} — interactive deploy"
  echo "" >&2

  local os_kind
  os_kind="$(detect_os)"
  case "$os_kind" in
    linux)   yellow "Detected: Linux" ;;
    darwin)  yellow "Detected: macOS" ;;
    windows) yellow "Detected: Windows-like (Git Bash)" ;;
    *)       yellow "Detected: unknown OS" ;;
  esac
  echo "" >&2

  echo "Environment tier:" >&2
  echo "  1) production  2) staging  3) dev  4) local" >&2
  local tier_choice
  tier_choice="$(prompt "4" "Choose tier (1-4 or name)")"
  local tier="local"
  case "$(echo "$tier_choice" | tr '[:upper:]' '[:lower:]')" in
    1|production) tier="production" ;;
    2|staging) tier="staging" ;;
    3|dev) tier="dev" ;;
    4|local) tier="local" ;;
    *) tier="local" ;;
  esac

  local default_domain="api.example.com"
  local default_port="9090"
  case "$tier" in
    production) default_domain="api.example.com"; default_port="9090" ;;
    staging)    default_domain="api-staging.example.com"; default_port="9091" ;;
    dev)        default_domain="api-dev.example.com"; default_port="9092" ;;
    local)      default_domain="nextpresskit.local"; default_port="9090" ;;
  esac
  if [[ -n "${NEXTPRESS_PUBLIC_HOST:-}" ]]; then
    default_domain="${NEXTPRESS_PUBLIC_HOST}"
  fi
  local service_unit="${APP_SERVICE_UNIT:-nextpresskit-backend}"
  local ssl_dir_default="${XDG_DATA_HOME:-"$HOME/.local/share"}/${APP_LOCAL_SSL_SUBDIR:-nextpresskit-ssl}"

  local gen_config
  gen_config="$(prompt_yn y "Generate Nginx (+ optional systemd) config files?")"

  local server_name="$default_domain"
  local deploy_dir="$ROOT_DIR"
  local app_port="$default_port"
  local listen_port="80"
  local include_systemd="n"
  local run_user="www-data"
  local run_group="www-data"
  local ssl_mode="none"
  local certbot_email="admin@example.com"
  local ssl_cert=""
  local ssl_key=""
  local listen_ssl="443"
  local redirect_http="y"

  if [[ "$gen_config" == "y" ]]; then
    server_name="$(prompt "$default_domain" "Nginx server_name (public hostname)")"
    default_deploy="/var/www/${service_unit}-${tier}"
    if [[ "$os_kind" == "darwin" || "$tier" == "local" ]]; then
      default_deploy="$ROOT_DIR"
    fi
    deploy_dir="$(prompt "$default_deploy" "Absolute app root (uploads alias, systemd WorkingDirectory)")"
    app_port="$(prompt "$default_port" "APP_PORT (Go listens here)")"
    listen_port="$(prompt "$([[ "$tier" == "local" ]] && echo "8080" || echo "80")" "Nginx HTTP listen port")"

    cyan "TLS / SSL for Nginx config:" >&2
    echo "  1) none (HTTP only)  2) Let's Encrypt (HTTP vhost + Certbot instructions)" >&2
    echo "  3) HTTPS with PEM files (mkcert, internal CA, or commercial cert)" >&2
    local ssl_pick
    ssl_pick="$(prompt "1" "Choose (1-3)")"
    case "$(echo "$ssl_pick" | tr -d '[:space:]')" in
      2)
        ssl_mode="letsencrypt"
        certbot_email="$(prompt "$certbot_email" "Email for Let's Encrypt (Certbot)")"
        ;;
      3)
        ssl_mode="pem"
        ssl_cert="$(prompt "${ssl_dir_default}/cert.pem" "Path to fullchain / certificate PEM")"
        ssl_key="$(prompt "${ssl_dir_default}/key.pem" "Path to private key PEM")"
        listen_ssl="$(prompt "443" "Nginx HTTPS listen port")"
        redirect_http="$(prompt_yn y "Add HTTP→HTTPS redirect on port ${listen_port}?")"
        ;;
      *)
        ssl_mode="none"
        ;;
    esac

    include_systemd="n"
    if [[ "$os_kind" == "linux" && "$tier" != "local" ]]; then
      include_systemd="$(prompt_yn y "Generate systemd unit file?")"
    elif [[ "$os_kind" == "linux" && "$tier" == "local" ]]; then
      include_systemd="$(prompt_yn n "Generate systemd unit? (optional on Ubuntu laptop)")"
    fi

    run_user="www-data"
    run_group="www-data"
    if [[ "$os_kind" == "darwin" || "$tier" == "local" ]]; then
      run_user="${SUDO_USER:-$USER}"
      run_group="$(id -gn "$run_user" 2>/dev/null || echo staff)"
    fi
    if [[ "$include_systemd" == "y" ]]; then
      run_user="$(prompt "$run_user" "systemd User")"
      run_group="$(prompt "$run_group" "systemd Group")"
    fi
  fi

  local slug
  slug="$(slugify "${tier}-${server_name}")"
  [[ -z "$slug" ]] && slug="${tier}-site"
  local gen_dir="$ROOT_DIR/deploy/generated/${slug}"
  mkdir -p "$gen_dir"

  if [[ "$gen_config" == "y" ]]; then
    local nginx_out="$gen_dir/nginx-${service_unit}-${tier}.conf"
    case "$ssl_mode" in
      none|letsencrypt)
        write_nginx_http "$nginx_out" "$server_name" "$listen_port" "$app_port" "$deploy_dir" "$tier"
        ;;
      pem)
        write_nginx_https "$nginx_out" "$server_name" "$listen_port" "$listen_ssl" "$app_port" "$deploy_dir" "$tier" "$ssl_cert" "$ssl_key" "$redirect_http"
        ;;
    esac

    if [[ "$include_systemd" == "y" ]]; then
      write_systemd "$gen_dir/${service_unit}@${tier}.service" "$tier" "$deploy_dir" "$run_user" "$run_group"
    else
      yellow "No systemd unit generated." >&2
    fi

    write_readme "$gen_dir/README.md" "$os_kind" "$tier" "$deploy_dir" "$gen_dir" "$ssl_mode" "$server_name" "$certbot_email"
    green "Wrote config under: $gen_dir" >&2

    if [[ "$os_kind" == "linux" || "$os_kind" == "darwin" ]] && _needs_hosts_entry "$server_name"; then
      if [[ "$(prompt_yn y "Add server_name host(s) to /etc/hosts → 127.0.0.1 (fixes ENOTFOUND in Postman/browsers)?")" == "y" ]]; then
        ensure_hosts_entries "127.0.0.1" "$server_name" || true
      fi
    fi

    if [[ "$ssl_mode" == "letsencrypt" ]] && [[ "$os_kind" == "linux" ]]; then
      if [[ "$(prompt_yn n "Run certbot --nginx now? (needs sudo, DNS must point here)")" == "y" ]]; then
        if command -v certbot >/dev/null 2>&1; then
          sudo certbot --nginx -d "$server_name" --email "$certbot_email" --agree-tos
        else
          red "certbot not found. Install: sudo apt install certbot python3-certbot-nginx"
        fi
      fi
    fi

    if [[ "$os_kind" == "linux" && "$(id -u)" -ne 0 ]]; then
      if [[ "$(prompt_yn n "Copy Nginx (+ systemd if any) into /etc now? (sudo)")" == "y" ]]; then
        sudo cp "$gen_dir/nginx-${service_unit}-${tier}.conf" "/etc/nginx/sites-available/${service_unit}-${tier}.conf"
        sudo ln -sf "/etc/nginx/sites-available/${service_unit}-${tier}.conf" /etc/nginx/sites-enabled/
        sudo nginx -t
        sudo systemctl reload nginx
        if [[ "$include_systemd" == "y" && -f "$gen_dir/${service_unit}@${tier}.service" ]]; then
          sudo cp "$gen_dir/${service_unit}@${tier}.service" "/etc/systemd/system/${service_unit}@${tier}.service"
          sudo systemctl daemon-reload
          yellow "Enable: sudo systemctl enable --now ${service_unit}@${tier}" >&2
        fi
      fi
    elif [[ "$os_kind" == "linux" && "$(id -u)" -eq 0 ]]; then
      yellow "Running as root: install paths manually if needed." >&2
    fi
  else
    yellow "Skipped config generation." >&2
  fi

  if [[ "$(prompt_yn y "Run release pipeline here (build, migrate, optional seed, restart service)?")" == "y" ]]; then
    run_release_pipeline "$tier"
  else
    if [[ "$gen_config" == "y" ]]; then
      cyan "Skipped release. See ${gen_dir}/README.md for generated configs." >&2
    else
      cyan "Skipped release." >&2
    fi
  fi

  green "Done." >&2
}

if [[ "${1:-}" == "apply-nginx" ]]; then
  shift
  apply_nginx_cli "$@"
  exit $?
fi

main "$@"
